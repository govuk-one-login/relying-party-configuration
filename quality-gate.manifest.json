{
  "$schema": "https://raw.githubusercontent.com/govuk-one-login/quality-gates/refs/tags/v0.2.0/schemas/schema.json",
  "services": [
    {
      "service-tag": "orchestration",
      "quality-gates": [
        {
          "check-types": ["code style and linting", "secret scanning"],
          "provider": "GitHub",
          "phase": "pre-merge",
          "config": {
            "file": ".github/workflows/validation.yml",
            "path": "jobs.style-checks"
          }
        },
        {
          "check-types": ["unit"],
          "provider": "GitHub",
          "phase": "pre-merge",
          "config": {
            "file": ".github/workflows/unit-tests.yml",
            "path": "jobs.unit-test"
          }
        },
        {
          "check-types": ["integration"],
          "provider": "GitHub",
          "phase": "pre-merge",
          "config": {
            "file": ".github/workflows/integration-tests.yml",
            "path": "jobs.integration-test"
          }
        },
        {
          "check-types": ["code quality", "unit test coverage"],
          "provider": "GitHub",
          "phase": "pre-merge",
          "config": {
            "file": ".github/workflows/sonarcloud.yml",
            "path": "jobs.check"
          }
        },
        {
          "check-types": ["code style and linting"],
          "provider": "GitHub",
          "phase": "pre-merge",
          "config": {
            "file": ".github/workflows/terraform-checks.yml",
            "path": "jobs.terraform-format"
          }
        },
        {
          "check-types": ["code style and linting"],
          "provider": "GitHub",
          "phase": "pre-merge",
          "config": {
            "file": ".github/workflows/terraform-checks.yml",
            "path": "jobs.terraform-validate"
          }
        },
        {
          "check-types": ["code style and linting"],
          "provider": "GitHub",
          "phase": "pre-merge",
          "config": {
            "file": ".github/workflows/checkov.yml",
            "path": "jobs.checkov"
          }
        }
      ]
    }
  ]
}
