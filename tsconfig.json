{
  "compilerOptions": {
    "module": "ESNext",
    "target": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "types": ["vitest/globals", "node"]
  },
  "include": [
    "src/**/*",
    "integration-tests/**/*",
    "vitest.integration.config.ts"
  ]
}
