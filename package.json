{
  "name": "relying-party-configuration",
  "version": "1.0.0",
  "license": "ISC",
  "type": "module",
  "engines": {
    "node": "24.14.x"
  },
  "scripts": {
    "dev": "nodemon",
    "lint": "prettier --check \"*/**/*.{ts,json}\" ; eslint . ",
    "lint:fix": "prettier . --write \"*/**/*.{ts,json}\" ; eslint . --fix",
    "test:unit": "vitest --run",
    "start:local": "sam local start-api --template template.yml --warm-containers EAGER",
    "test:integration": "vitest --run --config vitest.integration.config.ts",
    "localstack:up": "docker compose -f docker-compose.local.yml up -d",
    "localstack:down": "docker compose -f docker-compose.local.yml down"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1008.0",
    "@aws-sdk/lib-dynamodb": "^3.1008.0",
    "@eslint/compat": "^2.0.3",
    "esbuild": "^0.27.4",
    "jiti": "^2.6.1",
    "prettier": "^3.4.2",
    "vitest": "^4.0.18"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.161",
    "eslint": "^9.39.2",
    "nodemon": "^3.1.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.55.0"
  }
}