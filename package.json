{
  "name": "relying-party-configuration",
  "version": "1.0.0",
  "license": "ISC",
  "type": "module",
  "engines": {
    "node": "24.14.x"
  },
  "scripts": {
    "dev": "nodemon",
    "lint": "prettier --check \"*/**/*.{ts,json}\" ; eslint . ",
    "lint:fix": "prettier . --write \"*/**/*.{ts,json}\" ; eslint . --fix",
    "test:unit": "vitest --run",
    "build": "sam build --template template.yml --build-dir build",
    "start:local": "sam local start-api --template build/template.yaml --warm-containers EAGER",
    "test:integration": "vitest --run --config vitest.integration.config.ts",
    "test:ci:integration": "npm run start:local & (until curl --silent 127.0.0.1:3000/authorize; do sleep 1; done && npm run test:integration; exit 0)",
    "dynamodblocal:up": "docker compose -f dynamodb.local.yml up -d",
    "dynamodblocal:down": "docker compose -f dynamodb.local.yml down",
    "tflint": "tflint --chdir infra --recursive"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1014.0",
    "@aws-sdk/lib-dynamodb": "^3.1032.0",
    "@eslint/compat": "^2.0.5",
    "esbuild": "^0.27.4",
    "jiti": "^2.6.1",
    "prettier": "^3.8.3",
    "vitest": "^4.1.4",
    "eslint-plugin-playwright": "^2.5.1",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitest/eslint-plugin": "^1.6.9"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.161",
    "eslint": "^9.39.2",
    "nodemon": "^3.1.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.55.0"
  }
}
